# ─── Wayfinder OS lead wiring ──────────────────────────────────────────────
# Server-side proxy (Pattern B). These are read ONLY on the server (app/api/submit-lead).
# Set in Vercel for Production AND Preview separately. No NEXT_PUBLIC_ prefix = never in the browser bundle.
WAYFINDER_WEBHOOK_URL=https://YOUR-DEPLOYMENT.convex.site/api/funnel/clearmind-clearlife/lead
WEBHOOK_SECRET=your-per-funnel-api-key-from-wayfinder-admin

# ─── Analytics (client-side) ───────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Booking (client-side) ─────────────────────────────────────────────────
# Wayfinder round-robin booking slug -> https://www.wayfindercollective.io/book/team/<slug>
NEXT_PUBLIC_WAYFINDER_BOOKING_SLUG=

# ─── VSL (client-side, optional) ───────────────────────────────────────────
# YouTube video ID shown on the thank-you page after booking.
NEXT_PUBLIC_VSL_YOUTUBE_ID=
